rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidAppointment(data) {
      return data.title is string && 
             data.roomId is string && 
             data.start is string && 
             data.end is string && 
             data.date is string && 
             data.type in ['session', 'interview', 'survey'] &&
             data.recurrence in ['none', 'daily', 'weekly', 'weekdays'] &&
             data.selectedDays is list &&
             data.createdBy is string &&
             data.createdAt is string &&
             data.updatedAt is string;
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAppointment(incoming());
      allow update: if isSignedIn() && isValidAppointment(incoming()) && 
                    incoming().createdBy == existing().createdBy;
      allow delete: if isSignedIn();
    }

    match /professionals/{proId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
